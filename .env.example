# ─── Application ───────────────────────────────────────────────────────────────
APP_NAME="AI Healthcare Insurance Intelligence Platform"
APP_ENV=development
DEBUG=true

# ─── JWT / Security ────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── PostgreSQL (Async) ────────────────────────────────────────────────────────
POSTGRES_USER=insurance_user
POSTGRES_PASSWORD=insurance_pass
POSTGRES_DB=insurance_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://insurance_user:insurance_pass@postgres:5432/insurance_db

# ─── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION_CLAIMS=claims_vectors
CHROMA_COLLECTION_POLICIES=policy_vectors

# ─── LLM Provider (stub — swap via config) ─────────────────────────────────────
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-CHANGE_ME
OPENAI_MODEL=gpt-4o

# ─── Embedding Model ───────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ─── Redis (Semantic Cache) ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
# TTL for cached RAG responses (seconds). 3600 = 1 hour.
CACHE_TTL_SECONDS=3600
# Cosine similarity threshold for semantic cache hit [0.0–1.0].
# 0.92 = very strict (near-exact query match only).
# 0.85 = moderate (recommended for healthcare — avoids false hits on similar but
#        distinct clinical queries like "annual deductible" vs "out-of-pocket max").
CACHE_SIMILARITY_THRESHOLD=0.92
# Maximum number of cached entries in the Redis sorted set per tenant.
CACHE_MAX_ENTRIES_PER_TENANT=10000
# Local embedding model for cache key generation (no API cost).
# Uses sentence-transformers — much faster than calling OpenAI for cache checks.
CACHE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ─── Hybrid Search (BM25 + Dense) ─────────────────────────────────────────────
# Number of results from dense vector search leg
HYBRID_DENSE_TOP_K=20
# Number of results from BM25 sparse search leg
HYBRID_SPARSE_TOP_K=20
# Final number of results after RRF fusion (before cross-encoder pruning)
HYBRID_RRF_TOP_K=10
# RRF k constant — controls rank penalty steepness. 60 is the standard value.
HYBRID_RRF_K=60

# ─── Cross-Encoder Reranker ────────────────────────────────────────────────────
# HuggingFace model for cross-encoder reranking.
# ms-marco-MiniLM-L-6-v2 = fast, strong on retrieval tasks.
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# Chunks below this cross-encoder score are pruned from the LLM context.
# Range: typically -10 to +10 for this model. 0.0 is a reasonable floor.
RERANKER_SCORE_THRESHOLD=0.0
# Maximum chunks to pass to LLM context after reranking.
RERANKER_FINAL_TOP_K=5

# ─── Query Expansion ──────────────────────────────────────────────────────────
# Maximum number of synonym variants to generate per query term.
QUERY_EXPANSION_MAX_VARIANTS=3
# Whether to expand using the LLM (higher quality, ~500ms) or dictionary only
# (zero-latency). 'dictionary' is recommended for latency-sensitive endpoints.
QUERY_EXPANSION_BACKEND=dictionary

# ─── Kafka (EDA) ───────────────────────────────────────────────────────────────
# Leave blank to use MockKafkaProducer (development mode)
KAFKA_BOOTSTRAP_SERVERS=
# kafka:9092 for docker-compose; broker1:9092,broker2:9092 for production
KAFKA_CLAIMS_VALIDATED_TOPIC=claims.validated
KAFKA_CLAIMS_CLINICAL_REVIEW_TOPIC=claims.clinical_review
KAFKA_CLAIMS_STP_TOPIC=claims.stp
KAFKA_CLAIMS_DEAD_LETTER_TOPIC=claims.dead_letter
